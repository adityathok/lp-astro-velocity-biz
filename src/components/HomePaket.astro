---
import Button from '../components/Button.astro';
const items = [
    {
        title: 'Paket A',
        caption: 'Cocok untuk Individu atau UMKM yang baru mulai',
        price: 'Rp 3.000.000',
        email: 4,
        color: 'from-teal-400 to-teal-600 group-hover:from-teal-300'
    },
    {
        title: 'Paket B',
        caption: 'Cocok untuk Bisnis Berkembang dengan kebutuhan tinggi',
        price: 'Rp 6.000.000',
        email: 8,
        color: ' from-blue-400 to-blue-600  group-hover:from-blue-300'
    },
    {
        title: 'Paket C',
        caption: 'Cocok Organisasi & Perusahaan Besar untuk kebutuhan custom',
        price: 'Rp 9.000.000',
        email: 12,
        color: ' from-indigo-400 to-indigo-600 group-hover:from-indigo-300'
    }
]
