---
import { Image } from 'astro:assets';
import velocityLogo from '../assets/velocity-logo.webp';

const menuHeader = [
    {
        url:'/#hero',
        title: 'Home'
    },
    {
        url:'/#paketweb',
        title: 'Harga Web'
    },
    {
        url:'/#review',
        title: 'Testimoni'
    },
    {
        url:'/#faq',
        title: 'FAQ'
    },
    {
        url:'/#contact',
        title: 'Hubungi Kami'
    }
]
---

<header 
    class="fixed top-0 left-0 w-full z-50" 
    x-data="{
        menuMobile:false,
        scrolled: false,
        init() {
            this.scrolled = window.scrollY > 50
        }
    }"
    :class="scrolled?'bg-blue-900/70 backdrop-blur-sm shadow-md':''"
    @scroll.window="scrolled = window.scrollY > 50"
>
    <nav class="px-4 lg:px-6 py-4">
        <div class="flex flex-wrap justify-between items-center mx-auto max-w-7xl">
            <a href="/" class="flex items-center">
                <Image src={velocityLogo} class="mr-3 w-30 sm:w-40" loading="eager" alt="Velocity Logo"/>
            </a>
            <div class="flex items-center lg:order-2 md:hidden">                    
                <button @click="menuMobile = !menuMobile" data-collapse-toggle="mobile-menu-2" type="button" class="inline-flex items-center p-2 ml-1 text-sm text-gray-500 rounded-lg lg:hidden hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600" aria-controls="mobile-menu-2" aria-expanded="false">
                    <span class="sr-only">Open main menu</span>
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
                    <svg class="hidden w-6 h-6" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </button>
            </div>
            <div class="hidden justify-between items-center w-full lg:flex lg:w-auto lg:order-1" id="mobile-menu-2">
                
                <ul class="flex flex-col mt-4 font-sm text-sm lg:flex-row lg:space-x-8 lg:mt-0">
                    {menuHeader.map((item) => ( 
                    <li v-for="menu in menuHeader">
                        <a href={item.url} class="md:px-10 py-2 pr-4 pl-3 text-white rounded bg-primary-700 lg:bg-transparent lg:text-primary-700 lg:p-0 dark:text-white hover:opacity-70" aria-current="page">
                            {item.title}
                        </a>
                    </li>
                    ))}
                </ul>

            </div>
        </div>
    </nav>
    
    <div class="fixed bg-white z-1 top-0 h-screen w-screen px-10 py-20 shadow-md transition-all duration-300 ease-in-out md:hidden" :class="menuMobile?'opacity-100 scale-100 pointer-events-auto':'opacity-0 scale-95 pointer-events-none'">
        <div class="absolute top-0 right-0 p-2">
            <button type="button" @click="menuMobile = !menuMobile">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16">
                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
                </svg>
            </button>
        </div>
        <ul class="flex flex-col">
            {menuHeader.map((item) => ( 
                <li v-for="menu in menuHeader">
                    <a href={item.url} class="block py-4 pr-4 text-center text-lg font-bold border-b" aria-current="page">
                        {item.title}
                    </a>
                </li>
            ))}
        </ul>
    </div>

</header>
