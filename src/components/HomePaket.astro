<section id="paketweb" class="px-6 py-12 md:py-20 bg-radial-[at_50%_15%] from-gray-50 via-slate-50 to-slate-50">
    <div class="mx-auto max-w-7xl">
        <h2 class="text-center font-bold text-2xl md:text-4xl mb-6 md:mb-10">
            Harga Web
        </h2>
        <div class="grid grid-cols-12 gap-3 md:gap-5 xl:gap-10">

            {items.map((item) => (
                <div class="col-span-12 md:col-span-6 xl:col-span-4 shadow-sm hover:shadow-xl rounded-xl bg-white overflow-hidden group">
