---
import { Image } from 'astro:assets';
import ImgKlienBrimob from '../assets/klien-brimob.webp';
import ImgKlienBeacukai from '../assets/klien-beacukai.webp';
import ImgKlienMandiri from '../assets/klien-mandiri.webp';
import ImgKlienKejaksaan from '../assets/klien-kejaksaan.webp';
import ImgKlienTidore from '../assets/klien-tidore.webp';
import ImgAvatarDefault from '../assets/avatar-default.webp';
import Button from '../components/Button.astro';

import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

const items = [
    {
        img: ImgKlienBrimob,
        title: 'Brimob Sulawesi Tenggara'
    },
    {
        img: ImgKlienBeacukai,
        title: 'Bea Cukai Sabang Aceh'
    },
    {
        img: ImgKlienMandiri,
        title: 'Bank Mandiri Remittance Malaysia'
    },
    {
        img: ImgKlienKejaksaan,
        title: 'Kejaksaan Negeri Kepahiang Bengkulu'
    },
    {
        img: ImgKlienTidore,
        title: 'DPRD Tidore Kepulauan'
    }
]

const itemsUlasan = [
    {
        title: 'BPR Harta Tanamas - Bekasi, Jawa Barat',
        testimonial: 'Layanannya bagus, baik dan sangat cepat, pemberitahuannya juga jelas apabilan client ada yang tidak dimengerti team velocity selalu siap membantu dengan cepat, terima kasih.'
    },
    {
        title: 'Daryono Putra - Sidoarjo, Jawa Timur',
        testimonial: 'Saya sangat beruntung dan berterima kasih kepada velocity developer yg sudah banyak membantu menjadikan usaha saya menjadi profesional dgn adanya web.<br>Petugas yg siaga hingga malam untuk membantu 😊👍'
    },
    {
        title: 'Nur Hadi',
        testimonial: 'Hasil pekerjaan yang disajikan velocity betul2 sesuai dengan ekspektasi, dengan biaya terjangkau tetapi saya puas dengan hasil kerjanya. Staffnya ramah dan revisinya cepat. Recommended lah. Maju dan sukses terus untuk velocity'
    },
    {
        title: 'Yafet - Makassar, Sulawesi Selatan',
        testimonial: 'Saya sudah buat 3 website disini dan Sangat bagus serta respon sangat cepat jika kita bertanya juga memberikan arahan yang sangat baik. Solusi website murah tapi profesional ada disini deh.'
    }
]
---

<section id="klien" class="bg-white py-12 px-6 md:py-20">
    <div class="mx-auto max-w-7xl">

        <h2 class="text-center font-bold text-2xl md:text-3xl mb-6 md:mb-10 mx-auto max-w-2xl">
            Telah Dipercaya Oleh
        </h2>
        
        <div>  
            <div class="swiper mySwiper">
                <div class="swiper-wrapper">
                    {items.map((item) => (
                        <div class="swiper-slide">
                            <div class="text-center px-4 group">
                                <Image src={item.img} class="mx-auto max-w-40 opacity-70 grayscale transition-all group-hover:opacity-100 group-hover:grayscale-0" alt={item.title} loading="lazy"/>
                                <div class="text-xs md:text-sm text-slate-600 mt-1 px-4">{item.title}</div>
                            </div>
                        </div>
                    ))}

                </div>
            </div>
        </div>

    </div>
</section>

<section id="review" class="bg-white py-12 px-6 md:py-20">
    <div class="mx-auto max-w-7xl">
        <h2 class="text-center font-bold text-2xl md:text-4xl mb-2 md:mb-4">
            Reputasi Terbaik di Google Maps
        </h2>
        <p class="text-center mb-6 md:mb-10">
            Kami mendapatkan 1.200 ulasan di google maps bintang 5
        </p>

        <div class="swiper mySwiperUlasan">
            <div class="swiper-wrapper">
                {itemsUlasan.map((item) => (
                    <div class="swiper-slide py-2 px-3">
                        <div class="group shadow-md hover:shadow-lg rounded-xl p-4 md:p-8 min-h-65" x-data={`{ testi: ${JSON.stringify(item.testimonial)} }`}>
                            <div class="flex items-center gap-3 border-b border-slate-300 mb-4 pb-4">
                                <Image src={ImgAvatarDefault} class="h-10 w-10 object-cover rounded-full" alt={item.title} loading="lazy"/>
                                <div>
                                    <div class="text-sm font-bold mb-1">{item.title}</div>
                                    <div class="flex text-orange-300">
                                       <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16">
                                        <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                       </svg>
                                       <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16">
                                        <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                       </svg>
                                       <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16">
                                        <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                       </svg>
                                       <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16">
                                        <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                       </svg>
                                       <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16">
                                        <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                       </svg>
                                    </div>
                                </div>
                            </div>
                            <div class="text-sm text-slate-600 group-hover:text-slate-800 min-h-25 tracking-normal mt-3" x-html="testi"></div>
                        </div>
                    </div>
                ))}

            </div>
        </div>

        <div class="text-center mt-10">                       
            <Button link="https://maps.app.goo.gl/ePHZChMfra1wJHif6" target="_blank" color="secondary">                
                <div class="flex justify-center items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-geo-alt" viewBox="0 0 16 16">
                        <path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A32 32 0 0 1 8 14.58a32 32 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10"/>
                        <path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4m0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                    </svg>
                    Lihat ulasan Google Maps
                </div>
            </Button>
        </div>

    </div>
</section>


<script>
import Swiper from 'swiper';
import { Navigation, Pagination, Autoplay } from 'swiper/modules';

new Swiper('.mySwiper', {
  modules: [Navigation, Pagination, Autoplay],
  loop: true,
  autoplay: {
    delay: 3000,
    disableOnInteraction: false
  },
  breakpoints :{
        0: { slidesPerView: 2 },
        640: { slidesPerView: 3 },
        1024: { slidesPerView: 3 },
        1280: { slidesPerView: 4 }
    }
});

new Swiper('.mySwiperUlasan', {
  modules: [Navigation, Pagination, Autoplay],
  loop: true,
  autoplay: {
    delay: 4000,
    disableOnInteraction: false
  },
  breakpoints :{
        0: { slidesPerView: 1 },
        640: { slidesPerView: 2 },
        1024: { slidesPerView: 3 },
        1280: { slidesPerView: 3 }
    }
});
</script>