                        {item.title}
                    </div>
                    <div class="p-8 md:px-12">
                        <p class="text-sm text-center text-slate-500">{item.caption}</p>
                        <h3 class="mt-5 text-2xl md:text-3xl font-extrabold tracking-tighter text-center bg-linear-to-r from-slate-600 to-slate-900 group-hover:from-slate-400 text-transparent bg-clip-text">
                            {item.price}
